const FOLDER_ID = "1pgnhX7iHuxAMiWviDe5m0Q2B0VoxQ8oe"; 

function doGet() {
  return HtmlService.createTemplateFromFile('index')
      .evaluate()
      .addMetaTag('viewport', 'width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no')
      .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
}

function toNepNum(n) {
  const nepDigits = ['०','१','२','३','४','५','६','७','८','९'];
  return n.toString().replace(/\d/g, d => nepDigits[d]);
}

// 🔥 normalize (same)
function normalize(val) {
  return (val || "").toString().trim().replace(/\s+/g, " ");
}

function getLastKM(busNumber, currentMonthName) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const months = ["बैशाख", "जेठ", "असार", "साउन", "भदौ", "असोज", "कात्तिक", "मंसिर", "पुष", "माघ", "फागुन", "चैत"];
  let currentIndex = months.indexOf(currentMonthName);
  for (let i = currentIndex; i >= 0; i--) {
    let sheetName = "२०८३ " + months[i];
    let sheet = ss.getSheetByName(sheetName);
    let lastKM = searchKMInSheet(sheet, busNumber);
    if (lastKM !== null) return lastKM;
  }
  return 0;
}

function searchKMInSheet(sheet, busNumber) {
  if (!sheet) return null;
  const data = sheet.getDataRange().getValues();
  for (let j = data.length - 1; j >= 1; j--) {
    if (normalize(data[j][5]) === normalize(busNumber)) { 
      let val = parseFloat(data[j][10]); 
      if (!isNaN(val) && val > 0) return val;
    }
  }
  return null;
}

function process(data, photoObj) {

  // 🔥 LOCK (race condition fix)
  const lock = LockService.getScriptLock();
  lock.waitLock(30000);

  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheetName = "२०८३ " + data.nepMonthName;
    let sheet = ss.getSheetByName(sheetName) || ss.insertSheet(sheetName);
    
    // 🔥 KEY column add (last)
    const headers = ["मिति (BS)", "बार", "मिति (AD)", "प्रकार", "संस्था/रुट", "बस नं", "ड्राइभर", "लिटर", "रेट", "डिजल रकम", "आजको KM", "चलेको KM", "रिजर्भ रकम", "बैना/खर्च", "बचत", "कुल डिजल लिटर", "कुल डिजल रकम", "कुल रिजर्भ बचत", "विवरण", "फोटो", "KEY"];
    
    if (sheet.getLastRow() === 0) {
      sheet.appendRow(headers);
      sheet.getRange(1, 1, 1, headers.length)
        .setFontWeight("bold")
        .setBackground("#22c55e")
        .setFontColor("white")
        .setHorizontalAlignment("center")
        .setVerticalAlignment("middle");
      sheet.setFrozenRows(1);
    }

    // 🔥 UNIQUE KEY (main fix)
    const currentKey = (
      data.nepDateRaw + "|" +
      (data.entryType === "Institution" ? data.instName : data.routeFrom + "-" + data.routeTo) + "|" +
      data.busNumber
    ).toString().trim();

    // 🔥 FAST DUPLICATE CHECK (KEY column)
    const lastRow = sheet.getLastRow();
    if (lastRow > 1) {
      const keyData = sheet.getRange(2, 21, lastRow - 1, 1).getValues().flat();
      if (keyData.includes(currentKey)) {
        return "ERROR_DUPLICATE: यो बस (" + data.busNumber + ") को लागि आजको एन्ट्री भइसकेको छ!";
      }
    }

    // फोटो
    let photoLink = "फोटो छैन";
    if (photoObj && photoObj.base64) {
      const folder = DriveApp.getFolderById(FOLDER_ID);
      const blob = Utilities.newBlob(Utilities.base64Decode(photoObj.base64), photoObj.mimeType, photoObj.fileName);
      photoLink = '=HYPERLINK("' + folder.createFile(blob).getUrl() + '", "फोटो हेर्नुहोस्")';
    }

    const existingData = sheet.getDataRange().getValues();

    const nepType = data.entryType === "Institution" ? "संस्था" : "रिजर्भ";
    let runningDieselLiter = (parseFloat(data.dLiter) || 0);
    let runningDieselAmount = (parseFloat(data.dAmount) || 0);
    let runningReserveBalance = (data.entryType === "Reserve") ? (parseFloat(data.balance) || 0) : 0;
    
    if (existingData.length > 1) {
      for(let r = 1; r < existingData.length; r++) {
        const rowType = existingData[r][3] ? existingData[r][3].toString().trim() : ""; 
        const rowInstName = existingData[r][4] ? existingData[r][4].toString().trim() : "";
        const rowLiter = parseFloat(existingData[r][7]) || 0;
        const rowAmount = parseFloat(existingData[r][9]) || 0;
        const rowBal = parseFloat(existingData[r][14]) || 0;

        if (data.entryType === "Institution") {
          if (rowType === "संस्था" && rowInstName === data.instName) {
            runningDieselLiter += rowLiter;
            runningDieselAmount += rowAmount;
          }
        } else if (rowType === "रिजर्भ") {
          runningDieselLiter += rowLiter;
          runningDieselAmount += rowAmount;
          runningReserveBalance += rowBal;
        }
      }
    }

    const lastKMValue = parseFloat(data.lastKM) || 0;
    const todayKM = parseFloat(data.currentKM) || 0;
    const drivenKM = (todayKM > lastKMValue && lastKMValue > 0) ? (todayKM - lastKMValue) : 0;

    const rowData = [
      toNepNum(data.nepDateRaw), data.nepDay, data.engDate, nepType,
      (data.entryType === "Institution" ? data.instName : data.routeFrom + " - " + data.routeTo),
      data.busNumber, data.driverName,
      data.dLiter || 0, data.dRate || 0, data.dAmount || 0,
      todayKM, drivenKM,
      data.totalReserveAmount || 0, data.staffAllowance || 0, data.balance || 0,
      runningDieselLiter.toFixed(2), Math.round(runningDieselAmount),
      (data.entryType === "Reserve" ? Math.round(runningReserveBalance) : ""),
      data.remarks || "", photoLink,
      currentKey // 🔥 KEY SAVE
    ];

    sheet.appendRow(rowData);

    return "SUCCESS";

  } catch (e) {
    return "Error: " + e.toString();
  } finally {
    lock.releaseLock(); // 🔥 unlock
  }
}
